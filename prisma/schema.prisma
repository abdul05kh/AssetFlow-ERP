datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// -------------------------------------------------------------
// USER & ROLE MANAGEMENT
// -------------------------------------------------------------

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  phone        String?
  designation  String?
  status       String        @default("ACTIVE") // ACTIVE, INACTIVE
  departmentId String
  department   Department    @relation(fields: [departmentId], references: [id])
  
  userRoles    UserRole[]
  allocations  Allocation[]
  transfersFrom AssetTransfer[] @relation("TransfersFrom")
  transfersTo   AssetTransfer[] @relation("TransfersTo")
  transfersReq  AssetTransfer[] @relation("TransfersRequested")
  transfersApp  AssetTransfer[] @relation("TransfersApproved")
  bookings     ResourceBooking[]
  maintenanceRequestsRaised MaintenanceRequest[] @relation("RequestsRaised")
  maintenanceRequestsAssigned MaintenanceRequest[] @relation("RequestsAssigned")
  audits       Audit[]       @relation("AuditorRelation")
  logs         ActivityLog[]
  auditLogs    AuditLog[]
  notifications Notification[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique // e.g., "Administrator", "Asset Manager", "Employee"
  code            String           @unique // e.g., "ADMIN", "ASSET_MANAGER", "EMPLOYEE"
  description     String?
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  code            String           @unique // e.g., "ASSET_CREATE", "ASSET_DELETE"
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// -------------------------------------------------------------
// ORGANIZATION STRUCTURE
// -------------------------------------------------------------

model Department {
  id                 String       @id @default(uuid())
  code               String       @unique
  name               String       @unique
  parentDepartmentId String?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[] @relation("DepartmentHierarchy")
  departmentHeadId   String?
  status             String       @default("ACTIVE") // ACTIVE, INACTIVE
  description        String?
  users              User[]
  assets             Asset[]
  allocations        Allocation[]
  audits             Audit[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

// -------------------------------------------------------------
// ASSET REGISTRY & CATEGORIES
// -------------------------------------------------------------

model AssetCategory {
  id                         String   @id @default(uuid())
  name                       String   @unique
  description                String?
  sharedResource             Boolean  @default(false)
  defaultMaintenanceInterval Int      @default(30) // in days
  status                     String   @default("ACTIVE")
  assets                     Asset[]
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model Asset {
  id             String          @id @default(uuid())
  tag            String          @unique // Auto-generated e.g. AF-000001
  name           String
  serialNumber   String?         @unique
  categoryId     String
  category       AssetCategory   @relation(fields: [categoryId], references: [id])
  departmentId   String
  department     Department      @relation(fields: [departmentId], references: [id])
  acquisitionDate DateTime
  acquisitionCost Decimal
  currentLocation String
  condition      String          @default("NEW") // NEW, GOOD, FAIR, POOR, DAMAGED
  sharedResource Boolean         @default(false)
  status         String          @default("AVAILABLE") // AVAILABLE, ALLOCATED, RESERVED, UNDER_MAINTENANCE, LOST, RETIRED, DISPOSED
  warrantyExpiry DateTime?
  description    String?
  images         AssetImage[]
  allocations    Allocation[]
  transfers      AssetTransfer[]
  bookings       ResourceBooking[]
  maintenance    MaintenanceRequest[]
  auditItems     AuditItem[]
  attachments    Attachment[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model AssetImage {
  id        String   @id @default(uuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  url       String
  uploadedAt DateTime @default(now())
}
