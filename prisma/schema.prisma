datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// -------------------------------------------------------------
// USER & ROLE MANAGEMENT
// -------------------------------------------------------------

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  phone        String?
  designation  String?
  status       String        @default("ACTIVE") // ACTIVE, INACTIVE
  departmentId String
  department   Department    @relation(fields: [departmentId], references: [id])
  
  userRoles    UserRole[]
  allocations  Allocation[]
  transfersFrom AssetTransfer[] @relation("TransfersFrom")
  transfersTo   AssetTransfer[] @relation("TransfersTo")
  transfersReq  AssetTransfer[] @relation("TransfersRequested")
  transfersApp  AssetTransfer[] @relation("TransfersApproved")
  bookings     ResourceBooking[]
  maintenanceRequestsRaised MaintenanceRequest[] @relation("RequestsRaised")
  maintenanceRequestsAssigned MaintenanceRequest[] @relation("RequestsAssigned")
  audits       Audit[]       @relation("AuditorRelation")
  logs         ActivityLog[]
  auditLogs    AuditLog[]
  notifications Notification[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique // e.g., "Administrator", "Asset Manager", "Employee"
  code            String           @unique // e.g., "ADMIN", "ASSET_MANAGER", "EMPLOYEE"
  description     String?
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  code            String           @unique // e.g., "ASSET_CREATE", "ASSET_DELETE"
  description     String?
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// -------------------------------------------------------------
// ORGANIZATION STRUCTURE
// -------------------------------------------------------------

model Department {
  id                 String       @id @default(uuid())
  code               String       @unique
  name               String       @unique
  parentDepartmentId String?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  childDepartments   Department[] @relation("DepartmentHierarchy")
  departmentHeadId   String?
  status             String       @default("ACTIVE") // ACTIVE, INACTIVE
  description        String?
  users              User[]
  assets             Asset[]
  allocations        Allocation[]
  audits             Audit[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

// -------------------------------------------------------------
// ASSET REGISTRY & CATEGORIES
// -------------------------------------------------------------

model AssetCategory {
  id                         String   @id @default(uuid())
  name                       String   @unique
  description                String?
  sharedResource             Boolean  @default(false)
  defaultMaintenanceInterval Int      @default(30) // in days
  status                     String   @default("ACTIVE")
  assets                     Asset[]
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model Asset {
  id             String          @id @default(uuid())
  tag            String          @unique // Auto-generated e.g. AF-000001
  name           String
  serialNumber   String?         @unique
  categoryId     String
  category       AssetCategory   @relation(fields: [categoryId], references: [id])
  departmentId   String
  department     Department      @relation(fields: [departmentId], references: [id])
  acquisitionDate DateTime
  acquisitionCost Decimal
  currentLocation String
  condition      String          @default("NEW") // NEW, GOOD, FAIR, POOR, DAMAGED
  sharedResource Boolean         @default(false)
  status         String          @default("AVAILABLE") // AVAILABLE, ALLOCATED, RESERVED, UNDER_MAINTENANCE, LOST, RETIRED, DISPOSED
  warrantyExpiry DateTime?
  description    String?
  images         AssetImage[]
  allocations    Allocation[]
  transfers      AssetTransfer[]
  bookings       ResourceBooking[]
  maintenance    MaintenanceRequest[]
  auditItems     AuditItem[]
  attachments    Attachment[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model AssetImage {
  id        String   @id @default(uuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  url       String
  uploadedAt DateTime @default(now())
}

// -------------------------------------------------------------
// ASSET WORKFLOWS (ALLOCATION, TRANSFER, RETURN)
// -------------------------------------------------------------

model Allocation {
  id                 String          @id @default(uuid())
  assetId            String
  asset              Asset           @relation(fields: [assetId], references: [id])
  employeeId         String?
  employee           User?           @relation(fields: [employeeId], references: [id])
  departmentId       String?
  department         Department?     @relation(fields: [departmentId], references: [id])
  allocationDate     DateTime        @default(now())
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  conditionOnReturn  String?
  notes              String?
  status             String          @default("ACTIVE") // ACTIVE, RETURNED
  transfers          AssetTransfer[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model AssetTransfer {
  id              String      @id @default(uuid())
  assetId         String
  asset           Asset       @relation(fields: [assetId], references: [id])
  allocationId    String
  allocation      Allocation  @relation(fields: [allocationId], references: [id])
  currentHolderId String
  currentHolder   User        @relation("TransfersFrom", fields: [currentHolderId], references: [id])
  targetHolderId  String
  targetHolder    User        @relation("TransfersTo", fields: [targetHolderId], references: [id])
  requestedById   String
  requestedBy     User        @relation("TransfersRequested", fields: [requestedById], references: [id])
  approvedById    String?
  approvedBy      User?       @relation("TransfersApproved", fields: [approvedById], references: [id])
  reason          String
  requestedDate   DateTime    @default(now())
  transferDate    DateTime?
  status          String      @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// -------------------------------------------------------------
// RESOURCE BOOKING
// -------------------------------------------------------------

model ResourceBooking {
  id         String   @id @default(uuid())
  resourceId String
  resource   Asset    @relation(fields: [resourceId], references: [id])
  employeeId String
  employee   User     @relation(fields: [employeeId], references: [id])
  startTime  DateTime
  endTime    DateTime
  purpose    String
  status     String   @default("REQUESTED") // REQUESTED, CONFIRMED, ONGOING, COMPLETED, CANCELLED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// -------------------------------------------------------------
// MAINTENANCE MANAGEMENT
// -------------------------------------------------------------

model MaintenanceRequest {
  id            String    @id @default(uuid())
  assetId       String
  asset         Asset     @relation(fields: [assetId], references: [id])
  requestedById String
  requestedBy   User      @relation("RequestsRaised", fields: [requestedById], references: [id])
  technicianId  String?
  technician    User?     @relation("RequestsAssigned", fields: [technicianId], references: [id])
  description   String
  priority      String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status        String    @default("PENDING") // PENDING, APPROVED, TECHNICIAN_ASSIGNED, IN_PROGRESS, RESOLVED, CLOSED, REJECTED
  cost          Decimal?
  notes         String?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// -------------------------------------------------------------
// VENDOR & PROCUREMENT
// -------------------------------------------------------------

model Vendor {
  id             String          @id @default(uuid())
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?
  status         String          @default("ACTIVE") // ACTIVE, INACTIVE
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  orderNumber String              @unique // PO-XXXXXX
  vendorId    String
  vendor      Vendor              @relation(fields: [vendorId], references: [id])
  orderDate   DateTime            @default(now())
  totalAmount Decimal
  status      String              @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, RECEIVED, CANCELLED
  items       PurchaseOrderItem[]
  attachments Attachment[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  assetName       String
  description     String?
  quantity        Int
  unitPrice       Decimal
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// -------------------------------------------------------------
// AUDIT MANAGEMENT
// -------------------------------------------------------------

model Audit {
  id           String      @id @default(uuid())
  name         String
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id])
  location     String
  startDate    DateTime
  endDate      DateTime
  auditorId    String
  auditor      User        @relation("AuditorRelation", fields: [auditorId], references: [id])
  status       String      @default("CREATED") // CREATED, ASSIGNED, VERIFICATION, DISCREPANCY, CLOSED
  items        AuditItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model AuditItem {
  id               String    @id @default(uuid())
  auditId          String
  audit            Audit     @relation(fields: [auditId], references: [id], onDelete: Cascade)
  assetId          String
  asset            Asset     @relation(fields: [assetId], references: [id])
  status           String    @default("VERIFIED") // VERIFIED, MISSING, DAMAGED
  discrepancyNotes String?
  verifiedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// -------------------------------------------------------------
// CORE SYSTEM LAYER
// -------------------------------------------------------------

model Attachment {
  id              String         @id @default(uuid())
  targetType      String // Asset, Maintenance, PurchaseOrder
  targetId        String
  assetId         String?
  asset           Asset?         @relation(fields: [assetId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  url             String
  filename        String
  uploadedAt      DateTime       @default(now())
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message     String
  eventType   String
  referenceId String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  action        String
  targetType    String
  targetId      String
  previousState String?
  currentState  String?
  remarks       String?
  timestamp     DateTime @default(now())
}

model AuditLog {
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  action        String // CREATE, UPDATE, DELETE
  tableName     String
  recordId      String
  changedValues String? // JSON string
  timestamp     DateTime @default(now())
  ipAddress     String?
  userAgent     String?
  correlationId String?
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
